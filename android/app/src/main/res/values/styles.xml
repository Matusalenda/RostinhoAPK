<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema principal -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#454343</item>
        <item name="colorPrimaryDark">#454343</item>
        <item name="colorAccent">#454343</item>
        <item name="android:statusBarColor">#454343</item>
        <item name="android:navigationBarColor">#454343</item>
    </style>

    <!-- Tema do app sem ActionBar -->
    <style name="AppTheme.NoActionBar"
        parent="Theme.AppCompat.DayNight.NoActionBar">

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <item name="android:background">#454343</item>
        <item name="android:statusBarColor">#454343</item>
        <item name="android:navigationBarColor">#454343</item>
    </style>

    <!-- Splash Android 12+ usando o ícone do app -->
    <style name="AppTheme.NoActionBarLaunch"
        parent="Theme.SplashScreen">

        <!-- Cor de fundo -->
        <item name="windowSplashScreenBackground">
            #454343
        </item>

        <!-- Ícone do app -->
        <item name="windowSplashScreenAnimatedIcon">
            @mipmap/ic_launcher
        </item>

        <!-- Remove animação do ícone (opcional) -->
        <item name="windowSplashScreenAnimationDuration">
            0
        </item>

        <!-- Tema após abrir -->
        <item name="postSplashScreenTheme">
            @style/AppTheme.NoActionBar
        </item>

    </style>

</resources>